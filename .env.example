# ============================================
# Clausion 로컬 개발 환경변수 템플릿
# ============================================
# 사용법:
#   cp .env.example .env
# 그 후 각 값을 채워주세요. .env 파일은 git에 올라가지 않습니다.
#
# 프로덕션 배포 시: Railway/Docker 환경변수로 직접 주입하세요.
# 절대로 실제 값이 담긴 .env 파일을 커밋하지 마세요.
# ============================================

# ── PostgreSQL ──
POSTGRES_DB=classpulse
POSTGRES_USER=classpulse
POSTGRES_PASSWORD=classpulse123

# ── Redis ──
REDIS_HOST=localhost
REDIS_PORT=6379

# ── RabbitMQ ──
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=classpulse
RABBITMQ_PASSWORD=dev_password

# ── OpenAI ──
# https://platform.openai.com/api-keys 에서 발급
OPENAI_API_KEY=

# ── AWS S3 ──
# 최소 권한(해당 버킷 PutObject/GetObject/DeleteObject)만 가진 IAM 유저 사용 권장
AWS_S3_BUCKET=gb-ljs
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── LiveKit ──
# 로컬 개발 시 livekit-server 로컬 실행 후 자체 키/시크릿 생성
# 프로덕션은 LiveKit Cloud 콘솔에서 발급
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_URL=ws://localhost:7880

# ── JWT ──
# 반드시 32바이트(256비트) 이상의 랜덤 값으로 생성. 예:
#   openssl rand -base64 48
# 또는 (Windows PowerShell):
#   [Convert]::ToBase64String([Security.Cryptography.RandomNumberGenerator]::GetBytes(48))
# "default-secret" 이나 "change-in-production" 이 포함된 값은 앱이 거부합니다.
JWT_SECRET=

# ── Spring ──
SPRING_PROFILES_ACTIVE=dev

# ── Frontend ──
VITE_API_URL=http://localhost:8080
VITE_WS_URL=ws://localhost:8080/ws
VITE_LIVEKIT_URL=ws://localhost:7880
